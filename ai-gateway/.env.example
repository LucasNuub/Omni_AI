# ==============================================================================
# AI Gateway Configuration Environment Variables (.env)
# ==============================================================================

# Session JWT Signing Secret
# Generate a secure one via command: openssl rand -hex 32
JWT_SECRET=dev-only-insecure-secret-change-me-before-deploying

# Master Encryption Key (Fernet Key-at-Rest)
# Keep blank for the first run! The backend will automatically generate one,
# persist it back to the active .env, and print it with a backup warning.
# If manually defining, use a valid 32-byte url-safe base64-encoded key.
MASTER_ENCRYPTION_KEY=

# Database Storage Path (Relative to backend/ container context)
DB_PATH=./data/gateway.db

# Admin User Bootstrapping (Invite-Only Gateway Initializer)
# The gateway will automatically create this admin account on first start
# if the database has zero registered users.
ADMIN_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=AdminPasswordChangeMe123!

# Additional Optional Gateway Overrides
# JWT_ALGORITHM=HS256
# JWT_EXPIRE_MINUTES=10080
# INVITE_EXPIRE_HOURS=72
# DISCOVERY_BENCHMARK_SAMPLE_SIZE=10
